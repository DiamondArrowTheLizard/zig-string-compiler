<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Gui.Views.MethodWindow"
        Title="Метод анализа" 
        Width="750" Height="600" 
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,20,0,10"/>
        </Style>
        <Style Selector="Border.image-container">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{DynamicResource MaterialDesignDivider}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BoxShadow" Value="0 2 10 0 #15000000"/>
        </Style>
    </Window.Styles>

    <ScrollViewer>
        <StackPanel Margin="25">
            <TextBlock Text="Метод анализа" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <TextBlock TextWrapping="Wrap" FontSize="15" LineHeight="24">
                Так как грамматика является регулярной, синтаксический анализ выполняется 
                <Run FontWeight="Bold">методом пошагового перехода по графу конечного автомата</Run>, 
                соответствующего грамматике G[Start].
            </TextBlock>

            <TextBlock TextWrapping="Wrap" FontSize="15" LineHeight="24" Margin="0,10,0,0">
                Каждое состояние автомата соответствует этапу обработки входной строки, 
                а переходы определяются терминальными символами (лексемами).
            </TextBlock>

            <TextBlock Text="Граф автоматной грамматики" Classes="h2" HorizontalAlignment="Center"/>
            
            <Border Classes="image-container" HorizontalAlignment="Center">
                <StackPanel>
                    <Image Source="avares://Gui/Assets/grammar.png" 
                           Stretch="Uniform" 
                           MaxWidth="650"
                           RenderOptions.BitmapInterpolationMode="HighQuality">
                        <ToolTip.Tip>
                            <TextBlock Text="Визуализация состояний ДКА"/>
                        </ToolTip.Tip>
                    </Image>
                </StackPanel>
            </Border>

            <TextBlock Text="© 2026 Модуль синтаксического анализа" 
                       HorizontalAlignment="Center" 
                       FontSize="11" 
                       Opacity="0.5" 
                       Margin="0,30,0,0"/>
        </StackPanel>
    </ScrollViewer>
</Window>