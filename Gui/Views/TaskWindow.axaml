<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Gui.Views.TaskWindow"
        Title="Постановка задачи" 
        Width="700" Height="500" 
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock.h2">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="0,15,0,10"/>
        </Style>
        <Style Selector="Border.code-box">
            <Setter Property="Background" Value="#f8f9fa"/>
            <Setter Property="BorderBrush" Value="#ddd"/>
            <Setter Property="BorderThickness" Value="1,1,1,1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <Style Selector="TextBlock.code">
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="Foreground" Value="#2c3e50"/>
        </Style>
    </Window.Styles>

    <ScrollViewer>
        <StackPanel Margin="20">
            <TextBlock Text="Постановка задачи" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,20"/>

            <TextBlock Text="Вариант задания №65" Classes="h2"/>
            <StackPanel Margin="10,0">
                <TextBlock Text="Тема:" FontWeight="Bold" Margin="0,5,0,0"/>
                <TextBlock Text="Объявление строковой константы на языке Zig" Margin="0,0,0,10"/>
                
                <TextBlock Text="Примеры конструкций:" FontWeight="Bold" Margin="0,5,0,0"/>
                <Border Classes="code-box">
                    <StackPanel>
                        <TextBlock Text="const GREETING: []const u8 = &quot;Hello World!&quot;;" Classes="code"/>
                        <TextBlock Text="const GREETING: []const u8;" Classes="code"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <TextBlock Text="Примеры корректных входных данных" Classes="h2"/>
            <StackPanel Margin="10,0">
                <Border Classes="code-box">
                    <TextBlock Text="const MSG: []const u8 = &quot;Test&quot;;" Classes="code"/>
                </Border>
                <Border Classes="code-box">
                    <TextBlock Text="const empty_str: []const u8 = &quot;&quot;;" Classes="code"/>
                </Border>
                <Border Classes="code-box">
                    <TextBlock Text="const STATUS123: []const u8;" Classes="code"/>
                </Border>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>