<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Gui.ViewModels"
        xmlns:views="clr-namespace:Gui.Views"
        xmlns:conv="clr-namespace:Gui.Converters"
        xmlns:avalonedit="clr-namespace:AvaloniaEdit;assembly=AvaloniaEdit"
        xmlns:dg="clr-namespace:Avalonia.Controls;assembly=Avalonia.Controls.DataGrid"
        x:Class="Gui.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Lexer Text Editor"
        Width="900" Height="600"
        MinWidth="600" MinHeight="400">

    <Window.Resources>
        <conv:TokenTypeToBrushConverter x:Key="TokenColorConverter"/>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="TextBlock.status">
            <Setter Property="Margin" Value="5,0"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto">
        <!-- Menu -->
        <Menu Grid.Row="0">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Новый" Command="{Binding NewFileCommand}" InputGesture="Ctrl+N"/>
                <MenuItem Header="_Открыть..." Command="{Binding OpenFileCommand}" InputGesture="Ctrl+O"/>
                <MenuItem Header="_Сохранить" Command="{Binding SaveFileCommand}" InputGesture="Ctrl+S"/>
                <MenuItem Header="Сохранить Как..." Command="{Binding SaveFileAsCommand}"/>
                <Separator/>
                <MenuItem Header="_Выйти" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Редактирование">
                <MenuItem Header="_Отменить" Command="{Binding UndoCommand}" InputGesture="Ctrl+Z"/>
                <MenuItem Header="_Повторить" Command="{Binding RedoCommand}" InputGesture="Ctrl+Y"/>
                <Separator/>
                <MenuItem Header="_Вырезать" Command="{Binding CutCommand}" InputGesture="Ctrl+X"/>
                <MenuItem Header="_Копировать" Command="{Binding CopyCommand}" InputGesture="Ctrl+C"/>
                <MenuItem Header="_Вставить" Command="{Binding PasteCommand}" InputGesture="Ctrl+V"/>
                <MenuItem Header="_Удалить" Command="{Binding DeleteCommand}" InputGesture="Delete"/>
                <Separator/>
                <MenuItem Header="_Выбрать Всё" Command="{Binding SelectAllCommand}" InputGesture="Ctrl+A"/>
            </MenuItem>
            <MenuItem Header="_Текст">
                <MenuItem Header="Постановка Задачи" Command="{Binding ShowTaskCommand}"/>
                <MenuItem Header="Грамматика" Command="{Binding ShowGrammarCommand}"/>
                <MenuItem Header="Классификация Грамматики" Command="{Binding ShowGrammarClassCommand}"/>
                <MenuItem Header="Метод Анализа" Command="{Binding ShowMethodCommand}"/>
                <MenuItem Header="Тестовый файл" Command="{Binding ShowTestCommand}"/>
                <MenuItem Header="Список литературы" Command="{Binding ShowReferencesCommand}"/>
                <MenuItem Header="Исходный код программы" Command="{Binding ShowSourceCommand}"/>
            </MenuItem>
            <MenuItem Header="_Запустить" Command="{Binding RunParserCommand}" InputGesture="F5"/>
            <MenuItem Header="_Помощь">
                <MenuItem Header="_Помощь" Command="{Binding ShowHelpCommand}" InputGesture="F1"/>
                <MenuItem Header="_О Программе" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- Toolbar -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="0,0,0,1" Padding="2">
            <StackPanel Orientation="Horizontal" Spacing="2">
                <Button Command="{Binding NewFileCommand}" ToolTip.Tip="New">
                    <Image Source="avares://Gui/Assets/new.png" Width="16" Height="16"/>
                </Button>
                <Button Command="{Binding OpenFileCommand}" ToolTip.Tip="Open">
                    <Image Source="avares://Gui/Assets/open.png" Width="16" Height="16"/>
                </Button>
                <Button Command="{Binding SaveFileCommand}" ToolTip.Tip="Save">
                    <Image Source="avares://Gui/Assets/save.png" Width="16" Height="16"/>
                </Button>
                <Separator Width="10" Background="Transparent"/>
                <Button Command="{Binding UndoCommand}" ToolTip.Tip="Undo">
                    <Image Source="avares://Gui/Assets/undo.png" Width="16" Height="16"/>
                </Button>
                <Button Command="{Binding RedoCommand}" ToolTip.Tip="Redo">
                    <Image Source="avares://Gui/Assets/redo.png" Width="16" Height="16"/>
                </Button>
                <Separator Width="10" Background="Transparent"/>
                <Button Command="{Binding CutCommand}" ToolTip.Tip="Cut">
                    <Image Source="avares://Gui/Assets/cut.png" Width="16" Height="16"/>
                </Button>
                <Button Command="{Binding CopyCommand}" ToolTip.Tip="Copy">
                    <Image Source="avares://Gui/Assets/copy.png" Width="16" Height="16"/>
                </Button>
                <Button Command="{Binding PasteCommand}" ToolTip.Tip="Paste">
                    <Image Source="avares://Gui/Assets/paste.png" Width="16" Height="16"/>
                </Button>
                <Separator Width="10" Background="Transparent"/>
                <Button Command="{Binding RunParserCommand}" ToolTip.Tip="Run Parser">
                    <Image Source="avares://Gui/Assets/run.png" Width="16" Height="16"/>
                </Button>
                <Button Command="{Binding ShowHelpCommand}" ToolTip.Tip="Help">
                    <Image Source="avares://Gui/Assets/help.png" Width="16" Height="16"/>
                </Button>
                <Button Command="{Binding ShowAboutCommand}" ToolTip.Tip="About">
                    <Image Source="avares://Gui/Assets/about.png" Width="16" Height="16"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- Editor and results with splitter -->
<Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="4"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <avalonedit:TextEditor x:Name="Editor" Grid.Row="0"
                                   Document="{Binding Document}"
                                   FontFamily="Consolas"
                                   FontSize="16"
                                   ShowLineNumbers="True"
                                   WordWrap="False"
                                   SyntaxHighlighting="C#"/>

            <GridSplitter Grid.Row="1" Height="4" Background="Gray" HorizontalAlignment="Stretch"/>

            <TabControl Grid.Row="2">
                <TabItem Header="Лексер">
                    <views:LexerResultsView DataContext="{Binding LexerResults}"
                                            NavigateTo="OnLexerNavigate"/>
                </TabItem>
                <TabItem Header="Парсер">
                    <views:ParserResultsView DataContext="{Binding ParserResults}"
                                             NavigateTo="OnParserNavigate"/>
                </TabItem>
            </TabControl>
        </Grid>

        <!-- Status bar -->
        <Border Grid.Row="3" BorderBrush="Gray" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding StatusText}" Classes="status"/>
                <TextBlock Text="{Binding EditorText.Length, StringFormat='Length: {0}'}" Classes="status"/>
                <TextBlock Text="{Binding IsModified, StringFormat='Modified: {0}'}" Classes="status"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>