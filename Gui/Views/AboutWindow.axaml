<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Gui.ViewModels"
        x:Class="Gui.Views.AboutWindow"
        x:DataType="vm:AboutViewModel"
        Title="About" Width="600" Height="200" WindowStartupLocation="CenterOwner">
    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
        <TextBlock Text="Компилятор строковой константы Zig" FontSize="16" FontWeight="Bold"/>
        <TextBlock Text="Работу выполнил: Дементьев Артём Андреевич, гр. АВТ-313" FontSize="14" FontWeight="Bold"/>
        <TextBlock Text="© 2026" Margin="0,20,0,0"/>
        <Button Content="OK" Click="CloseClick" Width="80" Margin="0,20,0,0"/>
    </StackPanel>
</Window>