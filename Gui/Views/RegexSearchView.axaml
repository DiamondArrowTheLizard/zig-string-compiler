<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:Gui.ViewModels"
             x:Class="Gui.Views.RegexSearchView"
             x:DataType="vm:RegexSearchViewModel">
    
    <Grid RowDefinitions="Auto,*,Auto" Margin="10">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="10" Margin="0,0,0,10">
            <TextBlock Text="Выберите шаблон поиска:" VerticalAlignment="Center"/>
            <ComboBox ItemsSource="{Binding Presets}" 
                      SelectedItem="{Binding SelectedPreset}" 
                      Width="320">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Name}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Content="Найти подстроки" Name="BtnSearch" Classes="accent" Padding="15,5"/>
        </StackPanel>

        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding Matches}"
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  GridLinesVisibility="All"
                  BorderThickness="1" 
                  BorderBrush="Gray"
                  Name="GridMatches">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Найденный фрагмент" Binding="{Binding Value}" Width="250"/>
                <DataGridTextColumn Header="Индекс" Binding="{Binding Index}" Width="100"/>
                <DataGridTextColumn Header="Длина" Binding="{Binding Length}" Width="100"/>
                <DataGridTextColumn Header="Строка" Binding="{Binding Line}" Width="100"/>
                <DataGridTextColumn Header="Столбец" Binding="{Binding Column}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="2" 
                   Text="{Binding SummaryText}" 
                   FontWeight="Bold" 
                   Margin="0,10,0,0" 
                   FontSize="13"/>
    </Grid>
</UserControl>